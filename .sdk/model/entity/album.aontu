                orig: "album_id"
                reqd: true
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/api/album/{albumId}"
          parts: [
            "api"
            "album"
            "{id}"
          ]
          rename: {
            param: {
              albumId: "id"
            }
          }
          select: {
            exist: [
              "id"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



