# Entity: album

main: kit: entity: album: {

  alias: field: {}

  fields: [
    {
      name: "artist"
      req: false
      type: "`$STRING`"
    }
    {
      name: "cover_art"
      req: false
      type: "`$STRING`"
    }
    {
      name: "genre"
      req: false
      type: "`$STRING`"
    }
    {
      name: "id"
      req: false
      type: "`$STRING`"
    }
    {
      name: "label"
      req: false
      type: "`$STRING`"
    }
    {
      name: "release_date"
      req: false
      type: "`$STRING`"
    }
    {
